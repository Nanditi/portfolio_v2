---
import Layout from "@layouts/Default.astro";
import RecentBlogPosts from "@components/generic/RecentBlogPosts.astro";
import MobileSocials from "@components/home/MobileSocials.astro";
import { Pill } from "@eliancodes/brutal-ui";
import { Button } from "@eliancodes/brutal-ui";
import { Card } from "@eliancodes/brutal-ui";
import SummaryCard from "@components/generic/SummaryCard.astro";
import { Image } from "astro:assets";

const communities = [
  { name: "code.drift", url: "https://youtu.be/AlO_u2SC0jE" },
  { name: "lab59", url: "https://docs.google.com/document/d/1JLik1bdX64cG-GEccpP7e6nbGDTYbCVkZBr3YLcIKho/edit?usp=sharing" },
  // have to replace this link w/ something that shows all of it together (the doc, insta event posters, lab photos)
  {
    name: "blob labs",
    url: "https://youtu.be/6N1Rv1qy8uE",
  },
  { name: "dra.ft", url: "https://dra-ft.site/" },
  {
    name: "RRAP hub",
    url: "https://photos.app.goo.gl/euWvkj2LGqrnXR5R9",
    // have to add more photos of happenings, community stuff, us
  },
];

const seeMore = [ 
{ name: "reach out to me on IG", url: "https://instagram.com/nanditi.k/" },
{ name: "check out my musical tinkering", url: "https://www.youtube.com/@nanditi" },
{ name: "breaking linkedin by my existence", url: "https://www.linkedin.com/in/nanditi/" },
]

import profilepic from '../assets/nksonicphoto.png';

---

<Layout title="Home" pageTitle="Nanditi | Home" description="Nanditi Portfolio">
  <main class="bg-pink p-6">
    <MobileSocials />
    <section id="about" class="grid md:grid-cols-8 gap-8 mt-4">
      <div class="col-span-2">
  
      <Image src={profilepic} class="object-cover h-full w-full rounded-lg md:col-span-2 border-3 border-black card-shadow" alt="Elian Van Cutsem" width="392" height="392" loading="lazy" decoding="async" />
      </div>
      <h2 class="hidden">nanditi khilnani</h2>
      <div class="col-span-4">
        <Card color="cyan">
          <div class="flex flex-col justify-between items-start gap-4">
           <p class="mt-1 outfit text-2xl md:text-4xl lg:text-5xl xl:text-6xl font-bold">
              nanditi khilnani
            </p>
            <p class="mt-1 mb-1 outfit text-lg sm:text-xl md:text-2xl lg:text-2xl xl:text-3xl">
              co-founder — <a href="https://www.ajaibghar.com/" target="_blank"><u>ajaibghar</u></a>
              <br>
              musician · live-coder · cultural technologist
              <br> 
              listener · world-builder · community cultivator
            </p>
            <!-- <Button target={'_self'} href='/blog/'>
              Check out the blog &rarr;
            </Button> -->
          </div>
        </Card>
      </div>
      <div class="col-span-2">
        <Card>
          <h2 class="text-lg md:text-2xl lg:text-4xl mb-3 dm-serif">
            what is ajaibghar?
          </h2>
          <p class="poppins">
            a creative technology studio & lab for art, culture & futures,
            trailblazing a transdisciplinary practice in arts & culture
            utilising the strengths of emerging technology, experience design,
            cultural strategy & community building.
          </p>
        </Card>
    
      </section>
    <section id="about2" class="grid md:grid-cols-8 gap-8 mt-4">
      <div class="col-span-6">
        <Card>
          <p class="poppins">
            this is my millionth attempt at writing a bio. simply put, i'm one of those fortunate few who hopped off the black-and-white, ultra-fancy big-tech treadmill to build a muddy but technicolor practice across music, code, culture, and community.
          </p>
          <p class="poppins" style="padding-top:15px">
            hi, i’m nanditi — a classically trained indian musician and live-coder, working with generative raga-based electronic music, immersive soundscapes, and code-driven performances. my work often begins not with code, but with listening — to places, people, memory, and everyday life — treating listening itself as a kind of technology.
          </p>
          <p class="poppins" style="padding-top:15px">
            through this, i build systems, performances, and learning spaces where sound, culture, and code come together — not as tools, but as practices.
          </p>
          <p class="poppins" style="padding-top:15px">
            my approach to technology is deeply shaped by community, care, and collaboration. i work with what could be called a feminist tech ethos — building playful, inclusive environments where people can enter through curiosity rather than expertise, and where making is collective, situated, and open-ended.
          </p>
          <p class="poppins" style="padding-top:15px">
            along with my tech-twin, <a href="https://computationalmama.xyz/" target="_blank" class="underline">computational mama</a>, i co-run <a href="https://www.ajaibghar.com/" target="_blank" class="underline">ajaibghar</a> — a creative-technology studio and community that creates culturally-rooted, accessible, and experimental tech-art. our work spans performances, exhibitions, and learning ecosystems, and has been showcased at india art fair, serendipity arts festival, wildcity, vogue india, vice media, and ACRI.
          </p>
          <p class="poppins" style="padding-top:15px">
            my journey spans a tech career at google india, followed by grassroots work with folk artists and cultural organisations across rajasthan — experiences that continue to shape how i think about technology not as abstraction, but as something lived, shared, and deeply contextual.
          </p>
          <p class="poppins" style="padding-top:15px">
            currently, i’m developing new performance formats like raga.exe, and expanding community-driven practices like code.drift — exploring what it means to design technology with care, context, and culture.
          </p>
        </Card>
      </div>

      <div class="col-span-2 space-y-4">
        <Card>
          <h2 class="text-lg md:text-2xl lg:text-4xl mb-4 dm-serif">
            communities i've been cultivating🪴
          </h2>
          <ul class="flex gap-4 flex-wrap">
            {
              communities.map((item) => (
                <li>
                  <Pill>
                    <a
                      class="sanchez"
                      href={item.url}
                      target="_blank"
                      title={`Go to ${item.name}`}
                    >
                      {item.name}
                    </a>
                  </Pill>
                </li>
              ))
            }
          </ul>
        </Card>

        <Card>
          <h2 class="text-lg md:text-2xl lg:text-4xl mb-4 dm-serif">
            what i'm up to?
          </h2>
          <ul class="flex gap-4 flex-wrap">
            {
              seeMore.map((item) => (
                <li>
                  <Pill>
                    <a
                      class="sanchez"
                      href={item.url}
                      target="_blank"
                      title={`Go to ${item.name}`}
                    >
                      {item.name}
                    </a>
                  </Pill>
                </li>
              ))
            }
          </ul>
        </Card>
      </div>
    </section>
    <RecentBlogPosts />
  </main>
</Layout>
