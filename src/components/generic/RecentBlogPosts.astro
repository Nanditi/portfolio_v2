---
import { getCollection } from 'astro:content';
import BlogList from '../blog/BlogList.astro';
import { Card } from '@eliancodes/brutal-ui';
import { Button } from '@eliancodes/brutal-ui';

interface Props {
  count?: number;
}

const { count } = Astro.props;

const posts = await getCollection('projects').then((posts) =>
  posts.reverse().slice(0, count ?? 3)
);
---

<section class='mt-8'>
  <Card>
    <div class='flex flex-row justify-between items-center mb-8 gap-2'>
      <h2 class='text-2xl md:text-4xl lg:text-6xl dm-serif whitespace-nowrap'>
        recent projects
      </h2>
      <div>
        <Button href='/projects/'>
          <span class='hidden sm:inline'>go to </span>projects &rarr;
        </Button>
      </div>
    </div>
    <BlogList posts={posts} />
  </Card>
</section>
